{
  "name": "quote-engine",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "db:generate": "pnpm --filter @quote-engine/db generate",
    "db:migrate": "pnpm --filter @quote-engine/db migrate",
