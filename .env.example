# ============================================================
# .env.local — Variables de entorno (NUNCA commitear)
# Copiar a .env.local y llenar los valores
# ============================================================

# Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=EAA...
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=cotizaciones@auctorum.com.mx

# Cloudflare (for DNS automation)
CF_API_TOKEN=...
CF_ZONE_ID=...

# App
NEXT_PUBLIC_APP_DOMAIN=auctorum.com.mx
VPS_IP=xxx.xxx.xxx.xxx
NODE_ENV=production

# Supabase Storage
STORAGE_BUCKET=tenant-assets
